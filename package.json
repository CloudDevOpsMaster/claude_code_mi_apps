{
  "name": "alipay-mini-program-workspace",
  "version": "1.0.0",
  "description": "Workspace para Alipay+ Mini Programs en Linux",
  "scripts": {
    "preview": "cd my-miniapp && miniprogram-cli preview",
    "upload": "cd my-miniapp && miniprogram-cli upload",
    "init-cli": "bash scripts/init-dev.sh",
    "dev": "cd my-miniapp && npm run dev",
    "dev:local": "node scripts/dev-server.js",
    "test": "jest --coverage --coverageDirectory=coverage --forceExit",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@antglobal/miniprogram-cli": "^2.0.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "my-miniapp/utils/helpers.js",
      "!node_modules/**",
      "!coverage/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [
    "alipay",
    "mini-program",
    "mobile",
    "development"
  ],
  "author": "Development Team",
  "license": "MIT"
}
