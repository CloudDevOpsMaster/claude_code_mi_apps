/**
 * pages/index/index.acss - Estilos de la página principal
 *
 * NOTA: Usar rpx como unidad responsiva (750rpx = ancho completo)
 * Alipay+ Mini Programs escalan automáticamente según el dispositivo
 */

.page-container {
  padding: 0;
  background-color: #f8f8f8;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Encabezado */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: white;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Secciones */
.section {
  background-color: white;
  margin: 16rpx;
  padding: 32rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  border-bottom: 3rpx solid #667eea;
  padding-bottom: 12rpx;
}

/* Contador */
.counter-section {
  text-align: center;
}

.counter-display {
  background-color: #f0f0f0;
  border-radius: 12rpx;
  padding: 40rpx;
  margin: 24rpx 0;
  border: 3rpx solid #667eea;
}

.counter-value {
  font-size: 96rpx;
  font-weight: bold;
  color: #667eea;
  line-height: 1;
}

/* Botones */
.button-group {
  display: flex;
  gap: 12rpx;
  margin: 24rpx 0;
  justify-content: center;
}

.btn {
  flex: 1;
  padding: 16rpx 24rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background-color: #667eea;
  color: white;
  min-width: 100rpx;
}

.btn-primary:active {
  background-color: #5568d3;
  transform: scale(0.95);
}

.btn-secondary {
  background-color: #e0e0e0;
  color: #333333;
  flex: 2;
}

.btn-secondary:active {
  background-color: #d0d0d0;
}

.btn-success {
  background-color: #48bb78;
  color: white;
  width: 100%;
  margin-top: 12rpx;
}

.btn-success:active {
  background-color: #38a169;
}

.btn-info {
  background-color: #4299e1;
  color: white;
  width: 100%;
  margin-top: 12rpx;
}

.btn-info:active {
  background-color: #3182ce;
}

/* Información del Usuario */
.user-section {
}

.info-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-weight: bold;
  color: #666666;
  font-size: 26rpx;
}

.value {
  color: #333333;
  font-size: 26rpx;
  text-align: right;
  flex: 1;
  margin-left: 16rpx;
}

/* Estado de carga */
.loading-text {
  color: #4299e1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.error-text {
  color: #f56565;
  background-color: #fff5f5;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  border-left: 4rpx solid #f56565;
}

/* API Response */
.api-response {
  background-color: #edf2f7;
  padding: 16rpx;
  border-radius: 8rpx;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: #2d3748;
}

/* Sección de API */
.api-section {
}

.helper-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  text-align: center;
}

/* Divider */
.divider {
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 32rpx 16rpx;
}

/* Footer */
.footer {
  background-color: #333333;
  color: #ffffff;
  text-align: center;
  padding: 32rpx;
  margin-top: auto;
}

.footer-text {
  font-size: 24rpx;
  color: #ffffff;
  line-height: 1.5;
}
