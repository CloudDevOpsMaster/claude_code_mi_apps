/**
 * app.acss - Estilos globales de la aplicación
 *
 * NOTA: Acss (Alipay CSS) es similar a CSS estándar pero con algunas
 * características propias de Alipay+ Mini Programs.
 * Unidad responsiva: rpx (750rpx = ancho completo de pantalla)
 */

/* Reset de estilos */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* Body global */
body,
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial,
    sans-serif;
  font-size: 28rpx;
  color: #333333;
  background-color: #f8f8f8;
  line-height: 1.5;
}

/* Texto base */
text {
  display: block;
  word-break: break-word;
}

/* Botones base */
button {
  font-size: 28rpx;
  border-radius: 8rpx;
  padding: 20rpx 30rpx;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

/* Vistas base */
view {
  display: block;
}

/* Scroll view */
scroll-view {
  overflow: auto;
}

/* Inputs y campos de texto */
input {
  padding: 16rpx 12rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 4rpx;
  font-size: 28rpx;
}

/* Imágenes */
image {
  display: block;
  max-width: 100%;
}

/* Divider */
.divider {
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 20rpx 0;
}

/* Padding utilities */
.p-16 {
  padding: 16rpx;
}

.p-32 {
  padding: 32rpx;
}

.mt-16 {
  margin-top: 16rpx;
}

.mb-16 {
  margin-bottom: 16rpx;
}
