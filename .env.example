# Configuración de Alipay+ Mini Program CLI
# Copia este archivo a .env y completa con tus valores reales
# NO COMMITS .env (está en .gitignore)

# Workspace ID de tu Mini Program Platform account
WORKSPACE_ID=your_workspace_id_here

# Super App ID (proporcionado por Alipay)
SUPER_APP_ID=your_super_app_id_here

# Mini Program ID único para tu aplicación
MINI_PROGRAM_ID=your_mini_program_id_here

# Access Key ID para autenticación del CLI
# Obtén esto desde: Mini Program Platform > Settings > API Credentials
CLI_ACCESS_KEY_ID=your_access_key_id_here

# Secret Access Key (MANTENER SECRETO)
# Obtén esto junto con CLI_ACCESS_KEY_ID
CLI_SECRET_ACCESS_KEY=your_secret_access_key_here

# (Opcional) URL base para requests en desarrollo
# Dejar en blanco para usar endpoints de producción de Alipay
API_BASE_URL=

# (Opcional) Enable verbose logging en CLI
DEBUG=false
